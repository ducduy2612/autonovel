# Anthropic-compatible API key
ANTHROPIC_API_KEY=sk-ai-v1-key-placeholder

# Anthropic-compatible endpoint (change for non-Anthropic providers)
AUTONOVEL_API_BASE_URL=https://zenmux.ai/api/v1
AUTONOVEL_ZAI_CODING_BASE=https://zenmux.ai/api/v1

AUTONOVEL_THINKING=on

# All roles use GLM-5.1
AUTONOVEL_WRITER_MODEL=deepseek/deepseek-v4-pro-free
AUTONOVEL_JUDGE_MODEL=deepseek/deepseek-v4-pro-free
AUTONOVEL_REVIEW_MODEL=deepseek/deepseek-v4-pro-free

# Gemini API key for image generation (free tier: 500 images/day)
GEMINI_API_KEY=AIzaSyApDZnCzCLVDhCuu0GN1_kq2mRwTKrkADI

# Image generation model (default: gemini-2.5-flash-image)
AUTONOVEL_IMAGE_MODEL=gemini-3.1-flash-image-preview

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Pipeline language code (supported: en, vi). Defaults to 'vi'.
AUTONOVEL_LANGUAGE=vi