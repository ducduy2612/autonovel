# Anthropic-compatible API key
ANTHROPIC_API_KEY=your-api-key-here

# Anthropic-compatible endpoint (change for non-Anthropic providers)
AUTONOVEL_API_BASE_URL=https://api.z.ai/api/anthropic

# All roles use GLM-5.1
AUTONOVEL_WRITER_MODEL=GLM-5.1
AUTONOVEL_JUDGE_MODEL=GLM-5.1
AUTONOVEL_REVIEW_MODEL=GLM-5.1

# Gemini API key for image generation (free tier: 500 images/day)
GEMINI_API_KEY=your-gemini-api-key-here

# Image generation model (default: gemini-2.5-flash-image)
AUTONOVEL_IMAGE_MODEL=gemini-2.5-flash-image

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Pipeline language code (supported: en, vi). Defaults to 'vi'.
AUTONOVEL_LANGUAGE=vi